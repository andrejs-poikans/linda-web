---
import Logo from "/public/svg/bookmark.svg";

const { lang } = Astro.props;
const otherLang = lang === "en" ? "lv" : "en";

const allPostsEn = Object.values(
  import.meta.glob(`/src/pages/en/**/*.md`, { eager: true }),
);

const allPostsLv = Object.values(
  import.meta.glob(`/src/pages/lv/**/*.md`, { eager: true }),
);

const normalizePath = (path: string) => path.replace(/\/+$/, "");

const collectGroups = (posts: any[]) =>
  posts
    .filter((post) => post.url)
    .sort((a, b) => normalizePath(a.url).localeCompare(normalizePath(b.url)))
    .reduce(
      (groups: Record<string, any[]>, post: any) => {
        const segments = post.url.split("/").filter(Boolean);
        const group = segments[1] || "*";
        const groupKey = group.split("-")[0];
        (groups[groupKey] ??= []).push(post);
        return groups;
      },
      {} as Record<string, any[]>,
    );

const groupsEn = collectGroups(allPostsEn);
const groupsLv = collectGroups(allPostsLv);

const allPosts = (lang === "en" ? allPostsEn : allPostsLv).filter(
  (post: any) => post.url.split("/").filter(Boolean).length > 1,
);

const postsByGroup = allPosts.reduce(
  (groups: Record<string, any[]>, post: any) => {
    const group = post.url.split("/").filter(Boolean)[1] || "*";
    (groups[group] ??= []).push(post);
    return groups;
  },
  {} as Record<string, any[]>,
);

const currentPath = normalizePath(Astro.url.pathname);
const currentLang = lang === "en" ? "en" : "lv";
const currentSegments = currentPath.split("/").filter(Boolean);
const currentGroupKey = currentSegments[1]?.split("-")[0] ?? "";

const sourceGroup =
  currentLang === "en" ? groupsEn[currentGroupKey] : groupsLv[currentGroupKey];
const targetGroup =
  currentLang === "en" ? groupsLv[currentGroupKey] : groupsEn[currentGroupKey];

const currentIndex = sourceGroup
  ? sourceGroup.findIndex(
      (post: any) => normalizePath(post.url) === currentPath,
    )
  : -1;

let languageSwitchPath = `/${otherLang}`;
if (currentIndex !== -1 && targetGroup && targetGroup[currentIndex]) {
  languageSwitchPath = normalizePath(targetGroup[currentIndex].url);
} else if (
  currentPath === `/${currentLang}` ||
  currentPath === `/${currentLang}/` ||
  currentPath === "/"
) {
  languageSwitchPath = `/${otherLang}`;
}
---

<header>
  <div class="menu">
    <!-- <div class="handle">
      <button class="dot"><span class="dot-figure"></span></button>
    </div> -->
    <!-- <div class="bookmark">
      <Logo fill="black" />
    </div> -->
    <ul class="nav-list">
      <li class="home"><a href={`/${lang}`}><h1>Linda Mence</h1></a></li>

      {
        Object.entries(postsByGroup).map(([group, posts]: any) => (
          <>
            <li class={group}>
              <div class="section">
                {posts[0]?.frontmatter?.sectionTitle && (
                  <h1>{posts[0].frontmatter.sectionTitle}</h1>
                )}

                {posts.map((post: any) => (
                  <h2>
                    <a href={post.url}>{post.frontmatter.title}</a>
                  </h2>
                ))}
              </div>
            </li>
          </>
        ))
      }

      <li class="lang-sw"><a href={languageSwitchPath}>{otherLang}</a></li>
    </ul>
  </div>
</header>

