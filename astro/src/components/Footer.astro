---
const { lang } = Astro.props;
const aView = lang === "en" ? "accessibility view" : "pieejamības skats";
const rView = lang === "en" ? "regular view" : "parasts skats";
---

<footer>
  <div class="reading-view">
    <button class="reading-toggle">
      <span class="a-view">{aView}</span>
      <span class="r-view">{rView}</span>
      <span class="dot-figure"></span>
    </button>
  </div>
</footer>

<script is:inline>
  function initReadingMode() {
    const readingToggle = document.querySelector(".reading-toggle");
    const aViewEl = document.querySelector(".a-view");
    const rViewEl = document.querySelector(".r-view");
    const body = document.body;

    if (!readingToggle || !aViewEl || !rViewEl) return;

    function setMode(isReading) {
      body.classList.toggle("reading", isReading);
      localStorage.setItem("readingMode", String(isReading));
    }

    // restore state
    const isReading = localStorage.getItem("readingMode") === "true";
    setMode(isReading);

    // prevent duplicate listeners
    readingToggle.onclick = () => {
      const nowReading = !body.classList.contains("reading");
      setMode(nowReading);
    };
  }

  // initial load
  initReadingMode();

  // Astro view transitions
  document.addEventListener("astro:page-load", initReadingMode);
</script>
