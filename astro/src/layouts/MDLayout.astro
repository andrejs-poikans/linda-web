---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
const { frontmatter } = Astro.props;

// const anim = {
//   old: {
//     name: "bump-down",
//     duration: "0.1s",
//     easing: "ease-in",
//     // direction: "reverse",
//   },
//   new: {
//     name: "bump-up",
//     duration: "0.1s",
//     easing: "ease-in",
//   },
// };

// const customTransition = {
//   forwards: anim,
//   backwards: anim,
// };
---

<Layout pageTitle={frontmatter.title} lang={frontmatter.lang}>
  <!-- <p>Published on: {frontmatter.pubDate.toString().slice(0, 10)}</p> -->
  <!-- <p>Written by: {frontmatter.author}</p> -->
  <!-- <img src={frontmatter.image.url} width="300" alt={frontmatter.image.alt} /> -->

  <!-- <div class="tags">
    {
      frontmatter.tags.map((tag: string) => (
        <p class="tag">
          <a href={`/tags/${tag}`}>{tag}</a>
        </p>
      ))
    }
  </div> -->

  <main>
    <div class="pagetitle"><h1>{frontmatter.title}</h1></div>
    <!-- build gallery if it exists -->
    {
      frontmatter.gallery && (
        <div class="gallery">
          {frontmatter.gallery.map((item: any) => {
            if (!item?.image) return null;

            return (
              <div class="gallery-wrap">
                <Image
                  format="webp"
                  src={item.image}
                  alt={item.alt || ""}
                  loading="lazy"
                  width="900"
                  quality="high"
                />
              </div>
            );
          })}
        </div>
      )
    }
    <slot />
  </main>
</Layout>
