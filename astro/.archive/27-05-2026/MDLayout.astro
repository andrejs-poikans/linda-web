---
import { Masonry } from 'astro-masonry';
import Layout from "../layouts/Layout.astro";
import Picture from 'astro/components/Picture.astro';
import Gallery from '../components/Gallery.jsx';
const { frontmatter } = Astro.props;
const galleryItems = frontmatter.gallery?.filter((item: any) => item?.image) ?? [];

---

<Layout title={frontmatter.sectionTitle ? `${frontmatter.sectionTitle}: ${frontmatter.title}` : `${frontmatter.title}`} lang={frontmatter.lang}>

  <main>
    <Masonry
      breakpointCols={{
        default: 3,
        700: 2,
        500: 1,

      }}
      debug= {false}
          >

          <!-- md body mandatory -->
        { frontmatter.title !== "index" && (
        <div class="md-container"> 
            <div class="path">
              {
                frontmatter.sectionTitle && (
                  <div class="sectiontitle">
                    <h1>{frontmatter.sectionTitle}</h1>
                  </div>
                  <span class="seperator">></span>
                )
              }
              {
                frontmatter.title !== "index" && (
                  <div class="pagetitle">
                    <h1>{frontmatter.title}</h1>
                  </div>
                )
              }
            </div>
            <div class="md-body">
                <slot />
            </div>
            <script type="module" >
              document.querySelectorAll('.md-body a').forEach((anchor) => {
                anchor.setAttribute('target', '_blank');
                anchor.setAttribute('rel', 'noopener noreferrer');
              });
            </script>
        </div>
        )}

             <!-- build gallery if it exists -->
            {
              galleryItems.length > 0 && (
                  <>
                      {galleryItems.map((item: any, index: number) => (
                        <button
                          type="button"
                          class="gallery-thumb"
                          data-gallery-id="page-gallery"
                          data-gallery-index={index}
                          aria-label={`Open image ${index + 1} of ${galleryItems.length}`}
                        >
                          <Picture
                            src={item.image}
                            alt={item.alt || ""}
                            format="webp"
                            layout="constrained"
                            fallbackFormat="jpg"
                            quality={80}
                            loading={index < 2 ? "eager" : "lazy"}
                            inferSize={true}
                            decoding="async"
                            sizes="(max-width: 700px) 100vw, 33vw"
                          />
                        </button>
                      ))}

                    <Gallery
                      items={galleryItems}
                      galleryId="page-gallery"
                      client:load
                    />
                  </>
              )
            }
        </Masonry>
  </main>
</Layout>
